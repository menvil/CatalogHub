# Application
APP_NAME=CatalogHub
APP_ENV=production
APP_KEY=CHANGE_ME
APP_DEBUG=false
APP_URL=https://CHANGE_ME
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=database
BCRYPT_ROUNDS=12

# Database
DB_CONNECTION=pgsql
DB_HOST=CHANGE_ME
DB_PORT=5432
DB_DATABASE=cataloghub
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME
DB_SSLMODE=require

# Redis, cache, and queues
REDIS_CLIENT=phpredis
REDIS_HOST=CHANGE_ME
REDIS_PORT=6379
REDIS_USERNAME=null
REDIS_PASSWORD=CHANGE_ME
REDIS_DB=0
REDIS_CACHE_DB=1
CACHE_STORE=redis
CACHE_PREFIX=cataloghub-production-cache-
QUEUE_CONNECTION=redis
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=120
QUEUE_FAILED_DRIVER=database-uuids

# Sessions
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

# Storage and media
FILESYSTEM_DISK=local
MEDIA_DISK=media
MEDIA_URL_DISK=public_media
PUBLIC_MEDIA_DISK=public_media
MEDIA_PATH_PREFIX=
MEDIA_UPLOAD_DISK=public
MEDIA_DISPATCH_VARIANTS_ON_UPLOAD=true
MEDIA_MAX_UPLOAD_WIDTH=8000
MEDIA_MAX_UPLOAD_HEIGHT=8000
MEDIA_MAX_UPLOAD_PIXELS=24000000

# S3-compatible storage (required only when an S3 disk is selected)
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_DEFAULT_REGION=CHANGE_ME
AWS_BUCKET=CHANGE_ME
AWS_URL=null
AWS_ENDPOINT=null
AWS_USE_PATH_STYLE_ENDPOINT=false

# Imports
IMPORTS_DISK=imports
IMPORT_ARTIFACT_PREFIX=imports
IMPORT_QUEUED_ARTIFACT_THRESHOLD_BYTES=5242880
IMPORT_SERIALIZED_PHP_MAX_BYTES=52428800
IMPORT_SERIALIZED_PHP_MAX_DEPTH=64
IMPORT_DUPLICATE_MIN_SCORE=0.55
IMPORT_PROCESSING_STALE_AFTER_SECONDS=90
IMPORT_MEDIA_DOWNLOAD_TIMEOUT=10
IMPORT_MEDIA_DOWNLOAD_MAX_BYTES=10485760

# Pricing freshness
PRICE_FRESH_HOURS=6
PRICE_STALE_HOURS=24
PRICE_EXPIRED_HOURS=48

# Mail
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=CHANGE_ME
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_ADDRESS=CHANGE_ME
MAIL_FROM_NAME="${APP_NAME}"

# Logging and error reporting
LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null
ERROR_REPORTING_ENABLED=false
ERROR_REPORTING_DSN=CHANGE_ME

# Client build (safe public value)
VITE_APP_NAME="${APP_NAME}"


{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "ext-gd": "*",
        "php": "^8.3",
        "filament/filament": "^5.6",
        "laravel/framework": "^13.8",
        "laravel/tinker": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.10",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
                "App\\Http\\Controllers\\ArchitectureFixtures\\": "tests/Fixtures/Architecture/Controllers/",
                "App\\Policies\\ArchitectureFixtures\\": "tests/Fixtures/Architecture/Policies/",
                "App\\Queries\\ArchitectureFixtures\\": "tests/Fixtures/Architecture/Queries/",
                "App\\Services\\ArchitectureFixtures\\": "tests/Fixtures/Architecture/Services/",
            "CatalogHub\\PHPStan\\": "tools/phpstan/src/",
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "analyse": "php -d memory_limit=1G vendor/phpstan/phpstan/phpstan analyse",
        "format": "pint",
        "format:test": "pint --test",
        "test": [
            "@php artisan config:clear --ansi @no_additional_args",
            "@php artisan test"
        ],
        "test:architecture": [
            "@php artisan test tests/Unit/Architecture",
            "@php tools/architecture/report.php"
        ],
        "test:database-boundaries": [
            "@php artisan config:clear --ansi @no_additional_args",
            "@php artisan test tests/Feature/Admin/MissingTranslationsScreenTest.php tests/Feature/Facets/FacetQueryBuilderSortingTest.php tests/Feature/Public/ProductPriceSortTest.php tests/Feature/Facets/FacetQueryBuilderRangeTest.php tests/Feature/Domains/Projections/ProjectionStaleDetectorTest.php tests/Feature/Public/SearchPageStubTest.php tests/Feature/SiteAdmin/CheapestProductsReportTest.php tests/Feature/SiteAdmin/OffersCoverageDashboardTest.php tests/Feature/CentralAdmin/StaleProductsScreenTest.php tests/Unit/Services/TranslationCompletenessServiceTest.php"
        ],
        "test:pagination-boundaries": [
            "@php artisan config:clear --ansi @no_additional_args",
            "@php artisan test tests/Feature/Admin/MediaLibraryTest.php tests/Feature/Public/ProductListingPageTest.php tests/Feature/SiteAdmin/ProductsWithoutOffersReportTest.php tests/Feature/SiteAdmin/CheapestProductsReportTest.php tests/Feature/Sites/ProductVisibilityManagerTest.php tests/Feature/Sites/BrandVisibilityRulesTest.php"
        ],
        "test:query-contracts": [
            "@php artisan config:clear --ansi @no_additional_args",
            "@php artisan test tests/Feature/Public/ProductListingPriceBlockTest.php tests/Feature/Public/ProductOffersBlockTest.php"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

includes:
    - vendor/larastan/larastan/extension.neon
    - tools/phpstan/architecture.neon

parameters:
    level: 5
    paths:
        - app
        - config
        - database
        - routes
        - tests
        - tools
    excludePaths:
        analyse:
            - tests/Fixtures/Architecture/*
    parallel:
        maximumNumberOfProcesses: 1

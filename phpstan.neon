includes:
    - vendor/larastan/larastan/extension.neon

parametersSchema:
    architecture: mixed()

services:
    -
        class: CatalogHub\PHPStan\Rules\NoInlineControllerValidationRule
        arguments:
            legacyExceptions: %architecture.controllerValidationExceptions%
        tags:
            - phpstan.rules.rule
    -
        class: CatalogHub\PHPStan\Rules\NoDirectControllerPermissionCheckRule
        arguments:
            legacyExceptions: %architecture.controllerPermissionExceptions%
        tags:
            - phpstan.rules.rule
    -
        class: CatalogHub\PHPStan\Rules\RestrictedDatabaseFacadeRule
        arguments:
            lowLevelQueryExceptions: %architecture.lowLevelQueryExceptions%
        tags:
            - phpstan.rules.rule
    -
        class: CatalogHub\PHPStan\Rules\RestrictedRawQueryRule
        arguments:
            rawSqlExceptions: %architecture.rawSqlExceptions%
        tags:
            - phpstan.rules.rule

parameters:
    architecture:
        controllerPermissionExceptions: []
        controllerValidationExceptions: []
        lowLevelQueryExceptions: []
        rawSqlExceptions:
            -
                class: App\Domains\Projections\ProjectionStaleDetector
                methods: [whereRaw]
                reason: 'Driver-aware projection version comparison uses only internally generated identifiers.'
                bindings: internal_only
                behaviorTests: [tests/Feature/Domains/Projections/ProjectionStaleDetectorTest.php]
                status: legacy
                target: 'MR 7: Projection query boundary'
            -
                class: App\Domains\PublicSite\SiteContextResolver
                methods: [selectRaw]
                reason: 'Legacy EXISTS projection selects a constant literal.'
                bindings: literal_only
                behaviorTests: [tests/Feature/Public/HomePageTest.php]
                status: legacy
                target: 'MR 7: Public query boundary'
            -
                class: App\Http\Controllers\Public\SearchController
                methods: [whereRaw, orWhereRaw]
                reason: 'Escaped LIKE search requires an explicit ESCAPE clause with bound patterns.'
                bindings: required
                behaviorTests: [tests/Feature/Public/SearchPageStubTest.php]
                status: legacy
                target: 'MR 7: Public search query boundary'
            -
                class: App\Queries\Translations\MissingTranslationsQuery
                methods: [whereRaw]
                reason: 'Escaped LIKE search requires an explicit ESCAPE clause with a bound pattern.'
                bindings: required
                behaviorTests: [tests/Feature/Admin/MissingTranslationsScreenTest.php]
                status: approved
            -
                class: App\Services\Content\HomepageContentResolver
                methods: [selectRaw]
                reason: 'Legacy EXISTS projection selects a constant literal.'
                bindings: literal_only
                behaviorTests: [tests/Feature/Public/HomepageContentBlockTest.php]
                status: legacy
                target: 'MR 7: Content query boundary'
            -
                class: App\Services\Facets\FacetQueryBuilder
                methods: [orderByRaw]
                reason: 'Driver-aware JSON numeric ordering and portable NULL-last ordering contain no dynamic values.'
                bindings: internal_only
                behaviorTests: [tests/Feature/Facets/FacetQueryBuilderSortingTest.php]
                status: legacy
                target: 'MR 7: Facet expression boundary'
            -
                class: App\Services\Facets\FacetQueryBuilder
                methods: [whereRaw]
                reason: 'Driver-aware numeric JSON constraint binds the serialized comparison value.'
                bindings: required
                behaviorTests: [tests/Feature/Facets/FacetQueryBuilderRangeTest.php]
                status: legacy
                target: 'MR 7: Facet expression boundary'
            -
                class: App\Queries\Pricing\CheapestProductsQuery
                methods: [orderByRaw]
                reason: 'Best-merchant selection requires portable total-price ordering over price plus nullable delivery price.'
                bindings: literal_only
                behaviorTests: [tests/Feature/SiteAdmin/CheapestProductsReportTest.php]
                status: approved
            -
                class: App\Queries\Pricing\OfferCoverageQuery
                methods: [selectRaw]
                reason: 'Coverage reports require portable conditional and distinct grouped aggregates over site-scoped Eloquent queries.'
                bindings: literal_only
                behaviorTests: [tests/Feature/SiteAdmin/OffersCoverageDashboardTest.php]
                status: approved
            -
                class: App\Queries\Translations\TranslationStatusCountsQuery
                methods: [selectRaw]
                reason: 'Translation completeness requires portable grouped status counts without loading every translation row.'
                bindings: literal_only
                behaviorTests: [tests/Unit/Services/TranslationCompletenessServiceTest.php]
                status: approved
    level: 5
    paths:
        - app
        - config
        - database
        - routes
        - tests
        - tools
    excludePaths:
        analyse:
            - tests/Fixtures/Architecture/*
    parallel:
        maximumNumberOfProcesses: 1
